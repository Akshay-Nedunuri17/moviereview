{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/backend/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/webfrontend/dist/$1"
        }
    ],
    "functions": {
        "backend/api/index.js": {
            "runtime": "nodejs24.x",
            "memory": 1024,
            "maxDuration": 10
        }
    }
}